{
	"name": "blob-to-url",
	"description": "Zero-dependency utility for generating blob URLs and base64 data URIs. ESM, CJS, and UMD with TypeScript types.",
	"version": "0.3.1",
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"unpkg": "./dist/index.global.js",
	"license": "MIT",
	"scripts": {
		"clean": "rimraf dist dist-types",
		"build": "tsdown",
		"build:ci": "tsdown",
		"test": "vitest",
		"test:ci": "pnpm build && vitest run --reporter verbose",
		"prepublishOnly": "npm run build",
		"release:patch": "npm version patch && git push && git push --tags",
		"release:minor": "npm version minor && git push && git push --tags",
		"release:major": "npm version major && git push && git push --tags"
	},
	"files": [
		"dist"
	],
	"author": {
		"name": "devcomfort",
		"email": "im@devcomfort.me"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/devcomfort/blob-to-url.git"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.com",
		"access": "public"
	},
	"keywords": [
		"blob",
		"datauri",
		"base64",
		"stringify",
		"urlify"
	],
	"pnpm": {
		"overrides": {
			"vite": "6.4.2"
		}
	},
	"devDependencies": {
		"@types/node": "^22.10.10",
		"happy-dom": "^20.9.0",
		"rimraf": "^6.1.3",
		"tsdown": "^0.21.10",
		"typescript": "^5.7.3",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
